# https://finnhub.io/register — required for /stocks report API. Copy this file to
# .env.local, paste your key, then restart `npm run dev`.
# Vercel: name must be exactly FINNHUB_API_KEY; enable for Production (and Preview);
# save, then Redeploy the project so serverless picks it up.
FINNHUB_API_KEY=

# Supabase (https://supabase.com) — auth + saved watchlists / preferences
# Run SQL in supabase/migrations/20260407120000_user_data.sql in the Supabase SQL editor.
#
# Default URL is https://YOUR_PROJECT_REF.supabase.co (Project Settings → API).
# To show your own domain during OAuth (instead of *.supabase.co), use Supabase
# Custom Domains (paid add-on): e.g. https://api.finance.hub — then set that URL
# here, add https://api.finance.hub/auth/v1/callback in Google Cloud redirect URIs,
# and activate the domain in Supabase. Docs:
# https://supabase.com/docs/guides/platform/custom-domains
#
# Vanity subdomain (Pro+): e.g. https://your-brand.supabase.co — same idea, update
# this URL and Google redirect URIs after activation.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
